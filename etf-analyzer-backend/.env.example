# ──────────────────────────────────────────────────────────────
# ETF双框架智能分析系统 — 环境变量配置示例
# ──────────────────────────────────────────────────────────────

# 应用环境: development | production | testing
ENV=development

# 调试模式: true | false
DEBUG=false

# 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# 服务端口
PORT=8000

# 缠论分析配置
CHANLUN_MIN_KLINES=5
CHANLUN_CENTER_OVERLAP=3
CHANLUN_DIVERGENCE_METHOD=macd_area
CHANLUN_RESONANCE_THRESHOLD=70.0

# 丁昶框架阈值
DINGCHANG_COMPOSITE_THRESHOLD_BUY=80.0
DINGCHANG_COMPOSITE_THRESHOLD_HOLD=60.0
DINGCHANG_COMPOSITE_THRESHOLD_WATCH=40.0
